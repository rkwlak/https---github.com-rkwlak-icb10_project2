# .gitignore – 파이썬 데이터 분석 프로젝트
# ---------------------------------------------------
# Python 실행 파일 및 캐시
__pycache__/
*.py[cod]
*$py.class

# 가상 환경 디렉터리 (uv 로 만든 .venv)
.venv/

# Jupyter Notebook 및 IPython 체크포인트
.ipynb_checkpoints/
*.ipynb

# 데이터 파일 (버전 관리에서 제외)
# - 대용량 데이터 파일, 중간 결과물, 모델 파일 등
*.csv
*.tsv
*.xlsx
*.xls
*.parquet
*.json
*.h5
*.hdf5
*.db
*.sqlite3
*.npz
*.npy
*.pickle
*.pkl
# 데이터 디렉터리 전체 무시 (필요 시 주석 해제)
# data/

# 로그 및 임시 파일
*.log
*.tmp
*.bak
*.swp

# OS, IDE, 에디터 파일
.DS_Store
Thumbs.db
.idea/
.vscode/
*.sublime-workspace
*.sublime-project

# 기타 빌드, 배포 파일
build/
Dist/
*.egg-info/

# 환경 설정 파일 (민감 정보 포함 가능)
.env
*.env

# 테스트 및 커버리지 결과
htmlcov/
.coverage
.coverage.*
*.cover

# 파이썬 패키지 배포 파일
*.whl
*.spec

# 프로젝트 특수 파일
*.log
*.orig
*.rej

# 기타 무시하고 싶은 파일/디렉터리 (필요 시 추가)
# 예: large_data/   # 큰 데이터 디렉터리를 무시하려면 주석 해제
# 모든 숨김 파일/폴더 무시 (예외: .gitignore)
.*
!.gitignore
